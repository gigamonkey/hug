#!/usr/bin/env bash

set -euo pipefail

CLASP="./node_modules/.bin/clasp"

usage() {
  echo "Usage: $0 <description>" >&2
  echo "       $0 --rollback <version>" >&2
  exit 1
}

if [ $# -eq 0 ]; then
  usage
fi

# Get all non-HEAD deployment lines from list-deployments output
DEPLOYMENT_LINES=$($CLASP list-deployments | grep '^-' | grep -v '@HEAD')

if [ -z "$DEPLOYMENT_LINES" ]; then
  echo "Error: could not find a non-HEAD deployment to update" >&2
  exit 1
fi

LINE_COUNT=$(echo "$DEPLOYMENT_LINES" | wc -l | tr -d ' ')

if [ "$LINE_COUNT" -eq 1 ]; then
  SELECTED_LINE="$DEPLOYMENT_LINES"
else
  echo "Multiple deployments found. Choose one:"
  echo "$DEPLOYMENT_LINES" | nl -w1 -s') '
  printf "Choice: "
  read -r CHOICE
  SELECTED_LINE=$(echo "$DEPLOYMENT_LINES" | sed -n "${CHOICE}p")
  if [ -z "$SELECTED_LINE" ]; then
    echo "Error: invalid choice" >&2
    exit 1
  fi
fi

DEPLOYMENT_ID=$(echo "$SELECTED_LINE" | awk '{print $2}')
# Extract description from "- <id> @<version> - <description>" (empty if none)
DEPLOYMENT_DESC=$(echo "$SELECTED_LINE" | sed -n 's/^- [^ ]* @[^ ]* - \(.*\)/\1/p')

update_deployment() {
  local id="$1" version="$2"
  if [ -n "$DEPLOYMENT_DESC" ]; then
    $CLASP update-deployment "$id" -V "$version" -d "$DEPLOYMENT_DESC"
  else
    $CLASP update-deployment "$id" -V "$version"
  fi
}

if [ "$1" = "--rollback" ]; then
  [ $# -eq 2 ] || usage
  VERSION="$2"
  echo "Rolling back to version $VERSION (deployment $DEPLOYMENT_ID)..."
  update_deployment "$DEPLOYMENT_ID" "$VERSION"
  echo "Done."
  exit 0
fi

DESCRIPTION="$*"

echo "Pushing..."
$CLASP push

echo "Creating version..."
VERSION_OUTPUT=$($CLASP create-version "$DESCRIPTION")
echo "$VERSION_OUTPUT"
VERSION=$(echo "$VERSION_OUTPUT" | grep -oE 'version [0-9]+' | grep -oE '[0-9]+')

if [ -z "$VERSION" ]; then
  echo "Error: could not parse version number from: $VERSION_OUTPUT" >&2
  exit 1
fi

echo "Redeploying to version $VERSION (deployment $DEPLOYMENT_ID)..."
update_deployment "$DEPLOYMENT_ID" "$VERSION"
echo "Done."
